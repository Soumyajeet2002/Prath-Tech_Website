{
  "health": {
    "endpoint": "GET /health",
    "response": {
      "status": "ok"
    }
  },
  "sendEmail": {
    "endpoint": "POST /send-email",
    "request": {
      "to": "test@example.com",
      "subject": "Test Email from API",
      "text": "This is a test email from the Node.js API",
      "html": "<h3>Test Email</h3><p>This is a test email from the Node.js API</p>"
    },
    "response": {
      "messageId": "<message-id>",
      "accepted": ["test@example.com"],
      "rejected": [],
      "response": "250 OK"
    }
  },
  "sendOTP": {
    "endpoint": "POST /send-otp",
    "request": {
      "email": "user@example.com"
    },
    "response": {
      "status": "success",
      "message": "OTP sent successfully",
      "expiresIn": 300
    }
  },
  "verifyOTP": {
    "endpoint": "POST /verify-otp",
    "request": {
      "email": "user@example.com",
      "otp": "123456"
    },
    "response": {
      "status": "success",
      "message": "OTP verified successfully"
    }
  },
  "contactForm": {
    "endpoint": "POST /contact-form",
    "request": {
      "name": "John Doe",
      "phone": "9999999999",
      "email": "john@example.com",
      "aboutProject": "I need help with my web development project. Please contact me for more details about the requirements and timeline.",
      "otp": "123456"
    },
    "response": {
      "status": "success",
      "message": "Contact form submitted successfully! We will get back to you soon.",
      "messageId": "<message-id>"
    }
  },
  "contactCareer": {
    "endpoint": "POST /contact",
    "request": {
      "name": "Jane Smith",
      "email": "jane@example.com",
      "number": "8888888888",
      "subject": "Career Inquiry",
      "message": "I am interested in joining your team as a software developer.",
      "experience": "5",
      "position": "Senior Software Engineer"
    },
    "response": {
      "status": "success",
      "message": "Career application submitted successfully! We will review your application and get back to you soon.",
      "messageId": "<message-id>"
    }
  },
  "professionalDetails": {
    "endpoint": "POST /professional-details",
    "request": {
      "fullName": "Alex Johnson",
      "mobileNumber": "7777777777",
      "emailAddress": "alex@example.com",
      "role": "Software Engineer",
      "experienceYears": "3",
      "experienceMonths": "6",
      "currentCTC": "8",
      "expectedCTC": "12",
      "noticePeriod": "30"
    },
    "response": {
      "status": "success",
      "message": "Professional details submitted successfully! We will review your application and get back to you soon.",
      "messageId": "<message-id>"
    }
  },
  "errorResponses": {
    "validationError": {
      "status": "error",
      "message": "Required fields missing: Full Name, Mobile Number"
    },
    "fileValidationError": {
      "status": "error",
      "message": "Only PDF files are allowed for CV upload"
    },
    "otpExpired": {
      "status": "error",
      "message": "OTP has expired. Please request a new OTP."
    },
    "invalidOTP": {
      "status": "error",
      "message": "Invalid OTP"
    },
    "smtpError": {
      "status": "error",
      "message": "SMTP configuration missing: require SMTP_HOST, SMTP_USER, SMTP_PASS"
    }
  },
  "testScenarios": {
    "scenario1": {
      "description": "Complete OTP flow",
      "steps": [
        "1. POST /send-otp with email",
        "2. Check email for 6-digit OTP",
        "3. POST /verify-otp with email and OTP",
        "4. POST /contact-form with verified OTP"
      ]
    },
    "scenario2": {
      "description": "Career application with CV",
      "steps": [
        "1. POST /contact with experience/position fields",
        "2. Upload PDF/DOC/DOCX file (≤5MB)",
        "3. Receive confirmation email with attachment"
      ]
    },
    "scenario3": {
      "description": "Professional details application",
      "steps": [
        "1. POST /professional-details with all required fields",
        "2. Upload PDF CV file (≤5MB)",
        "3. Receive professional application email"
      ]
    }
  },
  "environmentVariables": {
    "required": {
      "SMTP_HOST": "smtp.gmail.com",
      "SMTP_PORT": "587",
      "SMTP_SECURE": "false",
      "SMTP_USER": "your-email@gmail.com",
      "SMTP_PASS": "your-app-password",
      "SMTP_FROM": "Your Name <your-email@gmail.com>"
    },
    "optional": {
      "PORT": "3000",
      "TO_EMAIL": "recipient@example.com"
    }
  }
}
